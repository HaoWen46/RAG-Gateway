# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raggateway
POSTGRES_PASSWORD=changeme
POSTGRES_DB=raggateway

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# vLLM
VLLM_ENDPOINT=http://localhost:8000

# OPA
OPA_ENDPOINT=http://localhost:8181

# Gateway
GATEWAY_PORT=8080
JWT_SECRET=changeme
RATE_LIMIT_RPM=60
# JWT_PUBLIC_KEY_PATH=/path/to/rsa_public.pem  # set to enable RS256; leave empty for HS256

# Retrieval
RETRIEVAL_GRPC_PORT=50051

# PageIndex Worker
PAGEINDEX_GRPC_PORT=50052

# Adapter Service
ADAPTER_GRPC_PORT=50053
